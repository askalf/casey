{
  "name": "casey-cli",
  "version": "0.1.0",
  "description": "AI IT service-desk CSR — intakes client tickets (email), triages by category/priority/tier, resolves Tier-1 itself, and routes technical issues to arnie (Tier-3). Pairs with arnie-cli; routes LLM calls through dario.",
  "keywords": [
    "it",
    "service-desk",
    "helpdesk",
    "csr",
    "tier-1",
    "triage",
    "support",
    "ticketing",
    "ai",
    "claude",
    "agent",
    "email"
  ],
  "author": "askalf (https://github.com/askalf)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/askalf/casey.git"
  },
  "homepage": "https://github.com/askalf/casey#readme",
  "bugs": "https://github.com/askalf/casey/issues",
  "type": "module",
  "bin": {
    "casey": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "dev": "tsx watch src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "chalk": "^5.6.2",
    "imapflow": "^1.3.5",
    "mailparser": "^3.9.9",
    "nodemailer": "^8.0.10",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.6.1",
    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
